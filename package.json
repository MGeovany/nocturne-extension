{
  "name": "nocturne",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && node scripts/package.mjs",
    "package:edge": "npm run build && node scripts/package-edge.mjs",
    "package:opera": "npm run build && node scripts/package-opera.mjs",
    "package:firefox": "npm run build && node scripts/package-firefox.mjs",
    "package:source": "node scripts/package-source.mjs",
    "build:safari": "tsc --noEmit && vite build -c vite.safari.config.ts",
    "package:safari": "npm run build:safari && node scripts/package-safari.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
