{
  "manifest_version": 3,
  "name": "404-AM",
  "version": "0.1.0",
  "description": "DevTools panel to inspect fetch and XHR requests on any page.",
  "minimum_chrome_version": "100",
  "devtools_page": "devtools.html",
  "permissions": ["storage", "cookies", "browsingData"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
